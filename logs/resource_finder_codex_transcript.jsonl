{"type":"item.started","item":{"id":"item_24","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - << 'PY'\nimport requests, xml.etree.ElementTree as ET, re, json\nqueries=[\n 'all:\\\"large language models\\\" AND all:novelty',\n 'all:\\\"creative text generation\\\" AND all:benchmark',\n 'all:\\\"diverse beam search\\\"',\n 'all:\\\"self-BLEU\\\" OR all:distinct-n',\n 'all:\\\"serendipity recommendation\\\"',\n 'all:\\\"language model decoding diversity\\\"'\n]\nns={'a':'http://www.w3.org/2005/Atom'}\nallp=[]\nfor q in queries:\n    url=f\\\"http://export.arxiv.org/api/query?search_query={requests.utils.quote(q)}&start=0&max_results=12\\\"\n    txt=requests.get(url,timeout=30).text\n    root=ET.fromstring(txt)\n    for e in root.findall('a:entry',ns):\n        idurl=e.find('a:id',ns).text.strip()\n        title=' '.join((e.find('a:title',ns).text or '').split())\n        summary=' '.join((e.find('a:summary',ns).text or '').split())\n        published=(e.find('a:published',ns).text or '')[:10]\n        year=published[:4]\n        authors=', '.join([au.find('a:name',ns).text for au in e.findall('a:author',ns)][:6])\n        arxiv_id=idurl.rsplit('/',1)[-1]\n        pdf=f\\\"https://arxiv.org/pdf/{arxiv_id}.pdf\\\"\n        allp.append({'query':q,'id':arxiv_id,'title':title,'summary':summary,'authors':authors,'year':year,'pdf':pdf})\n# dedupe\nseen=set(); ded=[]\nfor p in allp:\n    if p['id'] in seen: continue\n    seen.add(p['id']); ded.append(p)\nprint('TOTAL',len(ded))\nfor p in ded[:25]:\n    print(f\\\"{p['id']} | {p['year']} | {p['title']}\\\")\nwith open('/tmp/arxiv_candidates.json','w') as f: json.dump(ded,f,indent=2)\nprint('saved /tmp/arxiv_candidates.json')\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
