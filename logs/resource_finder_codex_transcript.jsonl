{"type":"item.started","item":{"id":"item_30","type":"command_execution","command":"/bin/bash -lc \"pwd && source .venv/bin/activate && python - << 'PY'\nimport requests, xml.etree.ElementTree as ET, re, os, textwrap\nids=['1904.09751v2','2102.01454v3','1911.03705v4','1610.02424v2','2405.00099v4','2502.12700v1','2406.14169v1','2508.04032v1','2502.13539v1','2409.16605v1']\nns={'a':'http://www.w3.org/2005/Atom'}\nmeta=[]\nfor aid in ids:\n    url=f'http://export.arxiv.org/api/query?id_list={aid}'\n    root=ET.fromstring(requests.get(url,timeout=30).text)\n    e=root.find('a:entry',ns)\n    if e is None:\n        print('missing',aid); continue\n    title=' '.join((e.find('a:title',ns).text or '').split())\n    summary=' '.join((e.find('a:summary',ns).text or '').split())\n    year=(e.find('a:published',ns).text or '')[:4]\n    authors=', '.join([au.find('a:name',ns).text for au in e.findall('a:author',ns)][:8])\n    short=re.sub(r'[\"'^a-z0-9]+'\"','_',title.lower()).strip('_')[:60]\n    fname=f'{aid.split(\\\"v\\\")[0]}_{short}.pdf'\n    pdf_url=f'https://arxiv.org/pdf/{aid}.pdf'\n    out=os.path.join('papers',fname)\n    r=requests.get(pdf_url,timeout=60)\n    r.raise_for_status()\n    with open(out,'wb') as f: f.write(r.content)\n    meta.append({'id':aid,'title':title,'year':year,'authors':authors,'summary':summary,'pdf_url':pdf_url,'file':fname})\n    print('downloaded',fname,len(r.content))\n\nwith open('papers/README.md','w') as f:\n    f.write('# Downloaded Papers\\\\n\\\\n')\n    for i,m in enumerate(meta,1):\n        f.write(f\\\"{i}. [{m['title']}]({m['file']})\\\\\\\\n\\\")\n        f.write(f\\\"   - Authors: {m['authors']}\\\\\\\\n\\\")\n        f.write(f\\\"   - Year: {m['year']}\\\\\\\\n\\\")\n        f.write(f\\\"   - arXiv: {m['id']}\\\\\\\\n\\\")\n        f.write(f\\\"   - Why relevant: {textwrap.shorten(m['summary'], width=220, placeholder='...')}\\\\\\\\n\\\\\\\\n\\\")\n\nimport json\nwith open('/tmp/paper_meta.json','w') as f: json.dump(meta,f,inde